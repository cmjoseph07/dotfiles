# Gruvbox syntax highlighting and pager colors.
# Set at global scope on every startup so the theme lives in this tracked
# file instead of hiding in machine-local fish_variables state.

set -g fish_color_normal EBDBB2
set -g fish_color_command 8EC07C
set -g fish_color_quote EEBD35
set -g fish_color_redirection 7FA2AC
set -g fish_color_end D65D0E
set -g fish_color_error CC241D
set -g fish_color_param 83A598
set -g fish_color_comment 665C54
set -g fish_color_match --background=32302F
set -g fish_color_selection --background=32302F
set -g fish_color_search_match --background=504945
set -g fish_color_history_current --bold
set -g fish_color_operator 689D6A
set -g fish_color_escape D4879C
set -g fish_color_cwd 8EC07C
set -g fish_color_cwd_root FB4934
set -g fish_color_valid_path --underline
set -g fish_color_autosuggestion 504945
set -g fish_color_user 98971A
set -g fish_color_host 83A598
set -g fish_color_cancel -r
set -g fish_color_status red
set -g fish_pager_color_completion EBDBB2
set -g fish_pager_color_description EEBD35
set -g fish_pager_color_prefix 8EC07C --bold
set -g fish_pager_color_progress E7D7AD --background=504945
set -g fish_pager_color_selected_background --background=32302F
