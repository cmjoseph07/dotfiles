# macOS Finder metadata
.DS_Store

# fish shell machine-local generated state
fish/fish_variables

# machine-specific fish overrides, never shared
fish/conf.d/99-local.fish

# macOS-only app state
raycast/

# herdr: only config.toml is portable config; the rest is runtime state, sockets, and logs
herdr/*
!herdr/config.toml

# configs not ready to push yet - still refining before they go up
nvim/

# retired: not cross-platform, kept locally but no longer pushed
ghostty/
zed/

# gh: account-bound, differs between work and personal machines
gh/

# machine-local runtime state, regenerated by the tools themselves
homebrew/
hunk/
